# ==============================================================================
# Dokploy Local Test Environment - Environment Variables
# ==============================================================================
# Copy this file to .env and adjust values as needed.
# These are used by the setup scripts and docker-compose.yml.
# ==============================================================================

# Dokploy image version (default: latest)
# Options: latest, canary, v0.28.7, etc.
DOKPLOY_VERSION=latest

# IP address for Docker Swarm advertising.
# For local testing, 127.0.0.1 is fine.
# For remote access or multi-node, use your machine's actual IP.
ADVERTISE_ADDR=127.0.0.1

# ------------------------------------------------------------------------------
# Ports
# Change these if you have conflicts with other services running locally.
# ------------------------------------------------------------------------------

# Dokploy dashboard
PORT_DASHBOARD=3000

# Traefik HTTP (used to route traffic to your deployed apps)
PORT_HTTP=80

# Traefik HTTPS (used to route traffic to your deployed apps)
PORT_HTTPS=443
